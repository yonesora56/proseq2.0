# Pinned versions for proseq2.0 Docker image (linux/arm64)
# Note: bioconda does not ship amd64-era pins (samtools 1.9, bedtools 2.28, etc.) for arm64.
CUTADAPT_VERSION=5.2
SEQTK_VERSION=1.5
PRINSEQ_VERSION=0.20.4
BWA_VERSION=0.7.19
SAMTOOLS_VERSION=1.23.1
BEDTOOLS_VERSION=2.31.1
BEDOPS_VERSION=2.4.42
UCSC_BEDGRAPHTOBIGWIG_VERSION=482
UCSC_BIGWIGTOBEDGRAPH_VERSION=482
PERL_VERSION=5.32.1

CUTADAPT_VERSION_EXPECT=5.2
SAMTOOLS_VERSION_EXPECT=1.23.1
BEDTOOLS_VERSION_EXPECT="bedtools v2.31.1"
BWA_VERSION_EXPECT=0.7.19-r1273
PRINSEQ_VERSION_EXPECT=0.20.4
